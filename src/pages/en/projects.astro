---
import BaseLayout from "../../layouts/BaseLayout.astro"
import GithubCard from "@components/GithubCard.astro"
---

<BaseLayout title = "Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects</div>
  </div>

  <GithubCard
    title="Oxidized Assistant"
    img="/projects/oxidized-assistant.png"
    desc="An alternative to Home Assistant created using Rust"
    url="https://github.com/Oxidized-Assistant"
    badge="WIP"
  />
  
  <div class="divider my-0"></div>

  <GithubCard
    title="Hotkeys"
    img="/projects/hotkeys.png"
    desc="Honeslty, I just wanted a macro to open the Terminal but AutoHotkey had to be the worst piece of software ever intended"
    url="https://github.com/Brodino96/hotkeys",
    badge="NEW"
  />
  <div class="divider my-0"></div>
</BaseLayout>
